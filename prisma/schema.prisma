generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ПОЛЬЗОВАТЕЛИ ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  name          String
  birthDate     DateTime?
  avatarUrl     String?

  // Лояльность
  loyaltyPoints Int         @default(0)
  loyaltyTier   LoyaltyTier @default(NOVICE)
  referralCode  String      @unique
  referredBy    String?

  // Связи
  orders        Order[]
  reviews       Review[]
  favorites     Favorite[]
  cartItems     CartItem[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

enum LoyaltyTier {
  NOVICE
  INITIATED
  MASTER
  SEER
}

// ==================== ЗАКАЗЫ ====================

model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         @unique @default(autoincrement())

  // Связи
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Данные о товаре (денормализовано)
  productSlug     String
  productTitle    String
  productImageUrl String?
  psychicName     String
  psychicSlug     String
  psychicAvatarUrl String?
  category        String

  // Заказ
  status          OrderStatus @default(PROCESSING)
  amount          Int
  oldPrice        Int?
  clientData      Json        @default("{}")

  // Результат
  generatedResult String?    @db.Text
  completedAt     DateTime?

  // Отзыв
  review          Review?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PROCESSING
  COMPLETED
  CANCELLED
}

// ==================== ОТЗЫВЫ ====================

model Review {
  id          String       @id @default(cuid())

  orderId     String       @unique
  order       Order        @relation(fields: [orderId], references: [id])
  userId      String?
  user        User?        @relation(fields: [userId], references: [id])

  productSlug String
  rating      Int
  text        String       @db.Text

  // Модерация
  status      ReviewStatus @default(APPROVED)

  // Сидинг
  isSeeded    Boolean      @default(false)
  authorName  String?
  authorAvatar String?

  createdAt   DateTime     @default(now())

  @@index([productSlug])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== ИЗБРАННОЕ ====================

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productSlug String

  createdAt   DateTime @default(now())

  @@unique([userId, productSlug])
  @@map("favorites")
}

// ==================== КОРЗИНА ====================

model CartItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productSlug String

  createdAt   DateTime @default(now())

  @@unique([userId, productSlug])
  @@map("cart_items")
}
